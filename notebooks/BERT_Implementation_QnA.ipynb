        "    context,\n",
        "    return_tensors=\"pt\"\n",
        ")\n",
        "\n",
        "print(inputs)\n",
        "# Forward pass\n",
        "outputs = model(**inputs) # Unpack the BatchEncoding object\n",
        "print(outputs)\n",
        "\n",
        "# Start and end logits\n",
        "start_logits = outputs.start_logits\n",
        "end_logits = outputs.end_logits\n",
        "\n",
        "# Predicted answer span\n",
        "answer_start = torch.argmax(start_logits, dim=1).cpu().numpy()[0] # Use dim and call .numpy()\n",
        "answer_end = torch.argmax(end_logits, dim=1).cpu().numpy()[0] + 1 # Use dim and call .numpy()\n",
        "\n",
        "# Decode answer\n",
        "answer = tokenizer.decode(\n",
        "    inputs[\"input_ids\"][0][answer_start:answer_end]\n",
        ")\n",
        "\n",
        "print(\"Question:\", question)\n",
        "print(\"Context:\", context)\n",
        "print(\"Answer:\", answer)"
